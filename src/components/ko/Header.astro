---
import { getRelativeLocaleUrl } from "astro:i18n";
---

<header class="site__header">
	<div class="wrapper">
		<nav class="site__nav">
			<a href={getRelativeLocaleUrl('ko', '/')} class="site__nav__home"
				><svg
					aria-hidden="true"
					xmlns="http://www.w3.org/2000/svg"
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round">
					<path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
					<path
						d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
				</svg><span class="visually-hidden">홈으로 가기</span></a
			>

			<a href={getRelativeLocaleUrl("ko", "/blog")} class="site__nav__blog"
				><span>블로그</span></a
			>
		</nav>
	</div>
</header>

<style>
.site__header {
	padding-block: 1rem;
	color: var(--on-surface);
	background-color: var(--surface-container);
}

.site__nav {
	display: flex;
	align-items: center;
	justify-content: space-between;
}

.site__nav__home,
.site__nav__blog {
	display: flex;
	gap: 1rem;
	align-items: center;
}

.site__header ul {
	padding: 0;
	margin: 0;
	list-style: none;
}

.site__header a {
	font-size: 1.5rem;
	color: inherit;
	text-decoration: none;
}

.site__header svg {
	display: block;
	width: 2rem;
	height: 2rem;
}

.site__header button {
	all: unset;
	box-sizing: border-box;
	display: block;
	color: var(--on-surface);
	cursor: pointer;
}

.site__header button:focus-visible {
	outline: 0.1em solid;
	outline-offset: 0.1em;
}

.site__nav__main {
	display: flex;
	gap: 1rem;
	align-items: center;
}

.site__nav__main li {
	height: fit-content;
	line-height: 1;
}

.site__nav__main button {
	height: fit-content;
}

.site__nav__main a {
	display: block;
	height: fit-content;
	line-height: 1;
}
</style>
