---
import { Image } from "astro:assets";
import profileImg from "../../assets/images/profile-600.webp";
import Header from "../../components/ko/Header.astro";
import ProjectCard from "../../components/ko/ProjectCard.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="홈">
	<Header />
	<main>
		<section class="hero" aria-labelledby="hero-heading">
			<div class="wrapper">
				<div class="hero__text">
					<h1 id="hero-heading" class="text-display-large">
						프론트엔드 개발자 안건욱이라고 합니다!
					</h1>
					<!-- <p class="text-headline-small">
				I build interfaces that are fast by default, accessible by design
			</p> -->
					<p class="text-headline-small">
						성능과 접근성에 집중하는 프론트엔드 개발자 입니다
					</p>
					<a href="mailto:agw76638@gmail.com" class="btn btn-primary clay"
						><svg
							aria-hidden="true"
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round">
							<path d="M16 2v2" />
							<path d="M7 22v-2a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2" />
							<path d="M8 2v2" />
							<circle cx="12" cy="11" r="3" />
							<rect x="3" y="4" width="18" height="18" rx="2" />
						</svg><span>연락하기</span></a
					>
				</div>
				<Image src={profileImg} class="clay" alt="A selfi of me" priority />
			</div>
		</section>
		<section class="projects" aria-labelledby="projects-heading">
			<div class="wrapper">
				<h2 class="projects-heading">프로젝트</h2>
				<div class="auto-grid">
					<ProjectCard />
				</div>
			</div>
		</section>
		<!-- <section>
			<div class="wrapper">
				<h2>Skills</h2>
			</div>
		</section>
		<section>
			<div class="wrapper">
				<h2>About</h2>
				<p>
					Frontend developer focused on performance and accessibility — the
					parts that matter even when no one notices. Still developing my eye
					for design, but I care about getting the details right.
				</p>
			</div>
		</section> -->
		<section class="connect" aria-labelledby="connect-heading">
			<div class="wrapper">
				<h2 id="connect-heading">Let's Connect!</h2>
				<ul class="connect__list">
					<li>
						<a href="mailto:agw76638@gmail.com" class="btn btn-primary clay"
							><svg
								aria-hidden="true"
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round">
								<path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7" />
								<rect x="2" y="4" width="20" height="16" rx="2" />
							</svg><span>이메일 보내기</span></a
						>
					</li>
					<li>
						<a class="connect__github" href="https://github.com/agw76638"
							><svg
								aria-hidden="true"
								xmlns="http://www.w3.org/2000/svg"
								width="16"
								height="16"
								fill="currentColor"
								class="bi bi-github"
								viewBox="0 0 16 16">
								<path
									d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8" />
							</svg>
							<span>Github</span></a
						>
					</li>
					<li>
						<a
							class="connect__linkedin"
							href="https://www.linkedin.com/in/gunnwook-ahn"
							><svg
								aria-hidden="true"
								xmlns="http://www.w3.org/2000/svg"
								width="16"
								height="16"
								fill="currentColor"
								class="bi bi-linkedin"
								viewBox="0 0 16 16">
								<path
									d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z" />
							</svg><span>Linkedin</span></a
						>
					</li>
				</ul>
			</div>
		</section>
	</main>
</Layout>
